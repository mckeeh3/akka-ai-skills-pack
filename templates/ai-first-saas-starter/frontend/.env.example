# Public browser-side WorkOS/AuthKit settings only. These VITE_ values are embedded in the frontend bundle.
# Local setup:
# 1. In WorkOS, add http://localhost:9000 as an AuthKit redirect/callback URI.
# 2. Copy the WorkOS public client id here.
# 3. Keep VITE_WORKOS_REDIRECT_URI equal to the Akka-hosted frontend origin.
VITE_WORKOS_CLIENT_ID=client_your_workos_client_id
VITE_WORKOS_REDIRECT_URI=http://localhost:9000

# Never add backend secrets here. Keep WORKOS_API_KEY, WORKOS_JWT_ISSUER,
# WORKOS_JWT_AUDIENCE, ADMIN_USERS, RESEND_API_KEY, invite sender credentials,
# database credentials, and service tokens in backend-only env vars.
