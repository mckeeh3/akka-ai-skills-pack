# AI-first SaaS starter backend environment template.
#
# Copy to .env before local manual testing:
#   cp .env.example .env
#   set -a
#   source .env
#   set +a
#
# Do not commit .env. Backend secrets must never be copied into frontend/.env.local
# or static assets. Only VITE_ variables are browser-public.

# -----------------------------------------------------------------------------
# Backend runtime variables
# -----------------------------------------------------------------------------

# Optional bootstrap/admin seed convention for downstream extension tasks.
# The scaffolded starter's in-memory test foundation seeds a tenant admin in code;
# production-ready projects should replace that with an audited bootstrap/import flow.
ADMIN_USERS="you@example.com:TENANT_ADMIN:tenant-starter"

# WorkOS/AuthKit is the supported browser user authentication service.
# Backend-only WorkOS server-side API key.
WORKOS_API_KEY="sk_test_or_sk_live_xxxxxxxxx"

# Optional WorkOS API base URL override for tests/proxies.
WORKOS_API_BASE_URL="https://api.workos.com"

# WorkOS JWT validation values when endpoint/deployment config reads them from env.
WORKOS_JWT_ISSUER="configured-workos-issuer"
WORKOS_JWT_AUDIENCE="configured-workos-audience"

# Public app URL used in invitation emails and account flows.
APP_PUBLIC_BASE_URL="http://localhost:9000"

# Production invitation/email delivery uses Resend. Local/dev/test code may use
# the captured outbox adapter; production readiness should fail or report
# not-ready when real send configuration is required and missing.
RESEND_API_KEY="re_xxxxxxxxx"
RESEND_FROM_EMAIL="Acme <onboarding@example.com>"
INVITE_EMAIL_FROM="Acme <onboarding@example.com>"
INVITE_EMAIL_SUBJECT="You're invited"
RESEND_API_BASE_URL="https://api.resend.com"

# Required only after adding model-backed Akka agent calls. The starter's default
# agent governance tests are deterministic and do not require this key.
OPENAI_API_KEY="sk-your-openai-api-key"

# -----------------------------------------------------------------------------
# Frontend build-time public variables
# -----------------------------------------------------------------------------
# The current scaffold is backend-first; if you copy/materialize the packaged
# React/Vite workstream frontend reference into this app, these VITE_ variables
# are embedded into the browser bundle and must be treated as public.
VITE_WORKOS_CLIENT_ID="client_your_workos_client_id"
VITE_WORKOS_REDIRECT_URI="http://localhost:9000"
