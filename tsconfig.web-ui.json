{
  "compilerOptions": {
    "target": "ES2020",
    "module": "none",
    "lib": ["DOM", "ES2020"],
    "strict": true,
    "noEmitOnError": true,
    "rootDir": "src/main/web-ui",
    "outDir": "src/main/resources/static-resources",
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["src/main/web-ui/**/*.ts"]
}
