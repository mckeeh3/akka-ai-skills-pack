# Public browser-side WorkOS/AuthKit settings only. These VITE_ values are embedded in the frontend bundle.
VITE_WORKOS_CLIENT_ID=client_your_workos_client_id
VITE_WORKOS_REDIRECT_URI=http://localhost:9000
# Use local-dev only for local runtime-validation/manual role testing with seeded emails.
VITE_APP_AUTH_MODE=workos

# Never add backend secrets here. Keep WORKOS_API_KEY, ADMIN_USERS,
# RESEND_API_KEY, invite sender credentials, OPENAI_API_KEY,
# model-provider ids/endpoints/timeouts, database credentials,
# and service tokens in backend-only env vars.
