# AI-first SaaS starter backend environment template.
#
# Copy to .env before local manual testing:
#   cp .env.example .env
#   set -a
#   source .env
#   set +a
#
# Do not commit .env. Backend secrets must never be copied into frontend/.env.local
# or static assets. Only VITE_ variables are browser-public.

# -----------------------------------------------------------------------------
# Backend runtime variables
# -----------------------------------------------------------------------------

# Explicit first-admin bootstrap allowlist for a clean local scaffold.
# Format: email:SAAS_OWNER_ADMIN:OWNER[,email:SAAS_OWNER_ADMIN:OWNER]
# Production/default startup bootstrap creates only SaaS Owner scoped
# SAAS_OWNER_ADMIN authority. Tenant/Customer admins are created later through
# governed Organization/Invitation flows after a valid scope exists. Unknown
# sign-ins are denied instead of silently self-registering.
ADMIN_USERS="you@example.com:SAAS_OWNER_ADMIN:OWNER"

# WorkOS/AuthKit is the supported browser user authentication service.
# Local setup: create a WorkOS application, add http://localhost:9000 as an
# AuthKit redirect/callback URI, copy the client id to frontend/.env.local, and
# keep the backend-only API key here. Do not put this key in frontend env files.
# The backend may use it to fetch the WorkOS user profile when an AuthKit
# access token has sub but omits email; local account/invitation state still
# remains the authorization source of truth.
WORKOS_API_KEY="sk_test_or_sk_live_xxxxxxxxx"

# Optional WorkOS API base URL override for tests/proxies.
WORKOS_API_BASE_URL="https://api.workos.com"

# WorkOS JWT validation values for backend bearer-token validation. Use the
# issuer/audience from the same WorkOS environment as VITE_WORKOS_CLIENT_ID.
WORKOS_JWT_ISSUER="https://api.workos.com/"
WORKOS_JWT_AUDIENCE="configured-workos-audience"

# Public app base URL used by the backend to build user-facing links in
# invitation emails and related account/onboarding flows. Set this to the URL
# a recipient can open in a browser; the raw invite token is appended by the
# backend as /accept?token=... and must not be exposed outside the email
# delivery/acceptance boundary.
#
# Local manual/test example:
APP_PUBLIC_BASE_URL="http://localhost:9000/"
#
# Real deployed URL example:
# APP_PUBLIC_BASE_URL="https://app.your-company.example/"

# Production invitation/email delivery uses Resend through the backend-only
# adapter boundary. Local/dev/test code should use the captured outbox adapter;
# production readiness fails or reports not-ready when these settings are
# required and missing. Never copy the Resend key or raw invitation tokens into
# frontend env files, browser DTOs, static assets, traces, or fixtures.
RESEND_API_KEY="re_xxxxxxxxx"
RESEND_FROM_EMAIL="Acme <onboarding@example.com>"
INVITE_EMAIL_FROM="Acme <onboarding@example.com>"
INVITE_EMAIL_SUBJECT="You're invited"
RESEND_API_BASE_URL="https://api.resend.com"

# Backend-only model-provider configuration for real model-backed workstream
# agents. These values also enable the optional provider smoke command
# `tools/smoke-ai-first-saas-starter-real-model.sh`; when OPENAI_API_KEY is
# absent, the smoke reports a skip so default CI/fullstack validation can pass
# without real secrets. Once the five core v0 workstreams use model-backed
# message submission, missing or blank provider values must block submission
# with an actionable error; runtime code must not silently fall back to
# deterministic placeholder text.
# Do not copy these values to frontend/.env.local, /api/me, workstream payloads,
# traces, fixtures, or static assets.
OPENAI_API_KEY="sk-your-openai-api-key"
OPENAI_MODEL_ID="gpt-4o-mini"
OPENAI_API_BASE_URL="https://api.openai.com/v1"
OPENAI_REQUEST_TIMEOUT_SECONDS="30"

# -----------------------------------------------------------------------------
# Frontend build-time public variables
# -----------------------------------------------------------------------------
# These VITE_ variables are embedded into the browser bundle and must be treated
# as public. They must match the WorkOS AuthKit app configured above.
VITE_WORKOS_CLIENT_ID="client_your_workos_client_id"
VITE_WORKOS_REDIRECT_URI="http://localhost:9000"
