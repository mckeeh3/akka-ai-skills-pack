# AI-first SaaS starter/backend environment template.
#
# Copy this file to .env and fill in values for your local machine:
#   cp .env.example .env
#
# Load it before running Maven or npm commands that need these values:
#   set -a
#   source .env
#   set +a
#
# Do not commit .env. Backend secrets must never be copied into frontend/.env.local
# or into src/main/resources/static-resources. Only VITE_ variables are browser-public.

# -----------------------------------------------------------------------------
# Backend runtime variables
# -----------------------------------------------------------------------------

# Explicit first-admin bootstrap allowlist for the AI-first SaaS starter.
# Format: email:TENANT_ADMIN:tenant-starter[,email:TENANT_ADMIN:tenant-starter]
# The starter FoundationRole enum does not include the legacy APP_ADMIN alias.
ADMIN_USERS="you@example.com:TENANT_ADMIN:tenant-starter"

# Required only for examples that call OpenAI-backed Akka agents.
OPENAI_API_KEY="sk-your-openai-api-key"

# WorkOS/AuthKit is the supported browser user auth service.
# WorkOS server-side API key. Backend-only secret.
WORKOS_API_KEY="sk_test_or_sk_live_xxxxxxxxx"

# Optional WorkOS API base URL override for tests/proxies.
WORKOS_API_BASE_URL="https://api.workos.com"

# WorkOS JWT validation values, when endpoint config reads them from env/deployment config.
# WORKOS_JWT_ISSUER="https://api.workos.com/..."
# WORKOS_JWT_AUDIENCE="your-workos-audience"

# Public app URL used in invitation emails and account flows.
APP_PUBLIC_BASE_URL="http://localhost:9000"

# Required invite email delivery settings. Backend-only secrets/config.
# User onboarding depends on email delivery; the app fails startup if these are missing.
RESEND_API_KEY="re_xxxxxxxxx"
INVITE_EMAIL_FROM="Acme <onboarding@example.com>"
INVITE_EMAIL_SUBJECT="You're invited"

# Resend sender and optional API base URL override for tests/proxies.
RESEND_FROM_EMAIL="Acme <onboarding@example.com>"
RESEND_API_BASE_URL="https://api.resend.com"

# -----------------------------------------------------------------------------
# Frontend build-time public variables
# -----------------------------------------------------------------------------
# VITE_ variables are embedded into the browser bundle at build time. Treat them
# as public. They are included here so sourcing .env before `cd frontend && npm
# run build` supplies the Vite build. Alternatively, copy frontend/.env.example
# to frontend/.env.local and set these values there.

VITE_WORKOS_CLIENT_ID="client_your_workos_client_id"
VITE_WORKOS_REDIRECT_URI="http://localhost:9000"
