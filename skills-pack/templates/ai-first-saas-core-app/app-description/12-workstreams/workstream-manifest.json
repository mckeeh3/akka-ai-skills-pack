      "icon": {"iconId": "policy-shield", "visualHint": "shield/checklist", "accentColorToken": "workstream.governance", "ariaLabel": "Governance and Policy workstream"},
      "attentionCategories": ["approval", "policy_conflict", "decision", "outcome_drift"],
      "surfaces": ["agent-governance-center", "decision-card", "audit-trace-explorer", "markdown_response", "system_message"],
      "capabilities": ["governance-decisions-audit", "managed-agent-foundation"],
      "expertiseBundle": "governance-policy-agent.md",
      "internalWorkers": ["policy-impact-simulation-worker"],
      "traceability": ["70-traceability/functional-agent-to-capability-map.md", "70-traceability/surface-to-capability-map.md"],
