      "functionalAgentId": "agent-admin-agent",
      "managedAgentDefinitionId": "agent-admin-agent",
      "defaultSurfaceId": "agent-governance-center",
      "readiness": "surface-ready",
      "instanceScope": "tenantId + selectedContextId + functionalAgentId",
      "authorizedActors": ["Agent Steward", "Tenant Admin", "Policy Owner", "Reviewer", "Auditor read-only where permitted"],
