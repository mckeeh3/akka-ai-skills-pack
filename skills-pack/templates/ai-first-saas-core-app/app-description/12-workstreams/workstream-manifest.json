{
  "manifestVersion": "workstream-manifest/v1",
  "idConventions": {
    "workstreamId": "kebab-case product vertical id, for example user-admin",
    "functionalAgentId": "kebab-case owning workstream agent id ending in -agent, for example user-admin-agent",
    "managedAgentDefinitionId": "tenant-governed AgentDefinition record id; may differ from functionalAgentId but must be mapped explicitly",
    "surfaceId": "stable structured surface id",
    "capabilityId": "stable governed capability family id"
  },
  "workstreams": [
    {
      "workstreamId": "my-account",
      "displayName": "My Account",
      "classification": "foundation",
      "functionalAgentId": "my-account-agent",
      "managedAgentDefinitionId": "my-account-agent",
      "defaultSurfaceId": "my-account-dashboard",
      "readiness": "surface-ready",
      "instanceScope": "tenantId + selectedContextId + functionalAgentId + accountId",
      "authorizedActors": ["active signed-in member for own account and permitted contexts"],
      "icon": {"iconId": "account-user", "visualHint": "user/profile", "accentColorToken": "workstream.account", "ariaLabel": "My Account workstream"},
      "attentionCategories": ["personal_queue", "context_profile_settings_issue", "accessible_workstream_summary"],
      "surfaces": ["my-account-dashboard", "markdown_response", "system_message"],
      "capabilities": ["secure-tenant-user-foundation", "frontend-shell-integration-patterns", "governance-decisions-audit"],
      "expertiseBundle": "my-account-agent.md",
      "internalWorkers": ["personal-attention-digest-worker"],
      "traceability": ["70-traceability/functional-agent-to-capability-map.md", "70-traceability/surface-to-capability-map.md"],
      "localValidation": ["validate-workstream-contracts", "validate-surface-contracts", "api/ui runtime smoke before runtime-ready"]
    },
    {
      "workstreamId": "user-admin",
      "displayName": "User Admin",
      "classification": "foundation",
