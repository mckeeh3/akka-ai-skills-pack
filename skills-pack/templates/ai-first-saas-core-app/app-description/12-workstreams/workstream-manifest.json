{
  "manifestVersion": "workstream-manifest/v1",
  "idConventions": {
    "workstreamId": "kebab-case product vertical id, for example user-admin",
    "functionalAgentId": "kebab-case owning workstream agent id ending in -agent, for example user-admin-agent",
    "managedAgentDefinitionId": "tenant-governed AgentDefinition record id; may differ from functionalAgentId but must be mapped explicitly",
    "surfaceId": "stable structured surface id",
    "capabilityId": "stable governed capability family id"
  },
  "workstreams": [
    {
      "workstreamId": "my-account",
      "displayName": "My Account",
      "classification": "foundation",
      "functionalAgentId": "my-account-agent",
      "managedAgentDefinitionId": "my-account-agent",
      "defaultSurfaceId": "my-account-dashboard",
      "readiness": "surface-ready",
      "instanceScope": "tenantId + selectedContextId + functionalAgentId + accountId",
      "authorizedActors": [
        "active signed-in member for own account and permitted contexts"
      ],
      "icon": {
        "iconId": "account-user",
        "visualHint": "user/profile",
        "accentColorToken": "workstream.account",
        "tooltip": "Manage profile, settings, context, and personal attention",
        "ariaLabel": "My Account workstream"
      },
      "attentionCategories": [
        "personal_queue",
        "context_profile_settings_issue",
        "accessible_workstream_summary"
      ],
      "surfaces": [
        "my-account-dashboard",
        "markdown_response",
        "system_message"
      ],
      "capabilities": [
        "secure-tenant-user-foundation",
        "frontend-shell-integration-patterns",
        "governance-decisions-audit"
      ],
      "expertiseBundle": "my-account-agent.md",
      "internalWorkers": [
        {
          "workerId": "personal-attention-digest-worker",
          "substrate": "AutonomousAgent task or workflow-backed worker, finalized during runtime implementation",
          "trigger": "my-account-dashboard action, attention producer, or scheduled signal defined in internal-agents.md",
          "authorityBasis": "service actor constrained to secure-tenant-user-foundation within selected organization/AuthContext scope",
          "capabilityId": "secure-tenant-user-foundation",
          "governedToolId": "myaccount.personal_attention.digest",
          "progressSurfaceId": "system_message",
          "resultSurfaceId": "my-account-dashboard",
          "failureSurfaceId": "system_message"
        }
      ],
      "traceability": [
        "70-traceability/functional-agent-to-capability-map.md",
        "70-traceability/surface-to-capability-map.md"
      ],
      "localValidation": [
        "validate-workstream-contracts",
        "validate-surface-contracts",
        "api/ui runtime smoke before runtime-ready"
      ]
    },
