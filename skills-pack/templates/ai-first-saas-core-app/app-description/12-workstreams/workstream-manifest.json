      "managedAgentDefinitionId": "user-admin-agent",
      "defaultSurfaceId": "user-admin-dashboard",
      "readiness": "surface-ready",
      "instanceScope": "tenantId + selectedContextId + functionalAgentId; optional customerId when customer context is selected",
      "authorizedActors": ["Tenant Admin", "Customer Admin within scope", "SaaS Owner support role with explicit support grant", "Auditor read-only where permitted"],
      "icon": {"iconId": "users-shield", "visualHint": "users/shield", "accentColorToken": "workstream.user-admin", "ariaLabel": "User Admin workstream"},
      "attentionCategories": ["failed_action", "overdue_item", "security_review", "manual_review"],
      "surfaces": ["user-admin-dashboard", "user-admin-user-list", "user-admin-user-account", "decision-card", "audit-trace-explorer", "markdown_response", "system_message"],
      "capabilities": ["secure-tenant-user-foundation", "managed-agent-foundation", "governance-decisions-audit"],
      "expertiseBundle": "user-admin-agent.md",
      "internalWorkers": ["access-review-triage-worker", "invitation-delivery-investigation-worker"],
      "traceability": ["70-traceability/functional-agent-to-capability-map.md", "70-traceability/surface-to-capability-map.md"],
      "localValidation": ["validate-workstream-contracts", "validate-surface-contracts", "api/ui runtime smoke before runtime-ready"]
    },
    {
      "workstreamId": "agent-admin",
      "displayName": "Agent Admin",
