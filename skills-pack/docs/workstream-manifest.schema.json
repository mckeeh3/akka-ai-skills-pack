{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/akka-ai-skills-pack/workstream-manifest.schema.json",
  "title": "Akka AI Skills Pack Workstream Manifest",
  "type": "object",
  "required": ["manifestVersion", "workstreams"],
  "properties": {
    "manifestVersion": { "const": "workstream-manifest/v1" },
    "idConventions": { "type": "object", "additionalProperties": { "type": "string" } },
    "workstreams": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/workstream" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "workstream": {
      "type": "object",
      "required": [
        "workstreamId",
        "displayName",
        "classification",
        "functionalAgentId",
        "managedAgentDefinitionId",
        "defaultSurfaceId",
        "readiness",
        "instanceScope",
        "authorizedActors",
        "icon",
        "attentionCategories",
        "surfaces",
        "capabilities",
        "traceability",
        "localValidation"
      ],
      "properties": {
        "workstreamId": { "type": "string", "pattern": "^[-a-z0-9]+$" },
        "displayName": { "type": "string", "minLength": 1 },
        "classification": { "enum": ["foundation", "domain-specific"] },
        "functionalAgentId": { "type": "string", "pattern": "^[-a-z0-9]+-agent$" },
        "managedAgentDefinitionId": { "type": "string", "minLength": 1 },
        "defaultSurfaceId": { "type": "string", "minLength": 1 },
        "readiness": { "enum": ["identified", "described", "surface-ready", "capability-ready", "expertise-ready", "runtime-ready", "production-ready"] },
        "instanceScope": { "type": "string", "minLength": 1 },
        "authorizedActors": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "icon": {
          "type": "object",
          "required": ["iconId", "visualHint", "accentColorToken", "tooltip", "ariaLabel"],
          "properties": {
            "iconId": { "type": "string", "minLength": 1 },
            "visualHint": { "type": "string", "minLength": 1 },
            "accentColorToken": { "type": "string", "minLength": 1 },
            "tooltip": { "type": "string", "minLength": 1 },
            "ariaLabel": { "type": "string", "minLength": 1 },
            "assetRef": { "type": "string" }
          },
          "additionalProperties": false
        },
        "attentionCategories": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "surfaces": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "capabilities": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "expertiseBundle": { "type": "string" },
        "internalWorkers": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "traceability": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "localValidation": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      },
      "additionalProperties": false
    }
  }
}
